{
  "version": "1.0",
  "description": "100 failure patterns for strategy optimization",
  "categories": [
    {
      "name": "Risk",
      "prefix": "PR",
      "description": "Risk management related patterns",
      "patterns": [
        {"id": "PR_001", "name": "stoploss_too_wide", "condition": "max_drawdown > 20", "action": "reduce_stoploss", "params": ["stoploss", -0.08], "severity": 0.9},
        {"id": "PR_002", "name": "stoploss_too_narrow", "condition": "win_rate < 0.40 AND profit_abs < 0", "action": "increase_stoploss", "params": ["stoploss", 0.05], "severity": 0.8},
        {"id": "PR_003", "name": "no_trailing_stoploss", "condition": "profit_factor > 1.5 AND max_drawdown > 15", "action": "enable_trailing", "params": ["trailing_stop", true], "severity": 0.7},
        {"id": "PR_004", "name": "trailing_too_tight", "condition": "total_trades < 50 AND profit_abs < 0", "action": "loosen_trailing", "params": ["trailing_stop_dist", 0.02], "severity": 0.6},
        {"id": "PR_005", "name": "position_sizing_too_aggressive", "condition": "max_drawdown > 25", "action": "reduce_position", "params": ["enter_position_sizing", -0.02], "severity": 0.9},
        {"id": "PR_006", "name": "position_sizing_too_conservative", "condition": "profit_abs > 100 AND max_drawdown < 5", "action": "increase_position", "params": ["enter_position_sizing", 0.01], "severity": 0.5},
        {"id": "PR_007", "name": "high_fee_erosion", "condition": "profit_factor < 1.2 AND total_trades > 100", "action": "reduce_trading", "params": ["timeframe", "4h"], "severity": 0.7},
        {"id": "PR_008", "name": "drawdown_recovery_slow", "condition": "max_drawdown > 20 AND recovery_time > 50", "action": "tighten_stoploss", "params": ["stoploss", -0.03], "severity": 0.6},
        {"id": "PR_009", "name": "risk_reward_too_low", "condition": "avg_trade_balance < 0 AND profit_factor < 1.0", "action": "widen_stoploss", "params": ["stoploss", 0.04], "severity": 0.8},
        {"id": "PR_010", "name": "consecutive_losses_high", "condition": "max_drawdown > 15", "action": "add_cooldown", "params": ["cooldown_time", 1], "severity": 0.7},
        {"id": "PR_011", "name": "over_leverage", "condition": "max_drawdown > 30", "action": "reduce_leverage", "params": ["leverage", 1], "severity": 0.9},
        {"id": "PR_012", "name": "margin_call_risk", "condition": "max_drawdown > 20", "action": "reduce_position", "params": ["enter_position_sizing", -0.03], "severity": 0.9},
        {"id": "PR_013", "name": "stop_hunt_vulnerable", "condition": "total_trades < 30", "action": "widen_stoploss", "params": ["stoploss", 0.02], "severity": 0.6},
        {"id": "PR_014", "name": "asymmetric_risk", "condition": "avg_trade_balance < 0", "action": "tighten_stoploss", "params": ["stoploss", -0.02], "severity": 0.7},
        {"id": "PR_015", "name": "variable_risk_exposure", "condition": "profit_stddev > profit_mean", "action": "fix_position_sizing", "params": ["enter_position_sizing", "fixed"], "severity": 0.5}
      ]
    },
    {
      "name": "Frequency",
      "prefix": "FR",
      "description": "Trading frequency related patterns",
      "patterns": [
        {"id": "FR_001", "name": "trades_too_low", "condition": "total_trades < 30", "action": "relax_entry", "params": ["entry_timeout", 0], "severity": 0.7},
        {"id": "FR_002", "name": "trades_too_high", "condition": "total_trades > 200", "action": "tighten_entry", "params": ["entry_timeout", 5], "severity": 0.8},
        {"id": "FR_003", "name": "over_trading", "condition": "total_trades > 150 AND profit_factor < 1.2", "action": "add_cooldown", "params": ["cooldown_time", 2], "severity": 0.8},
        {"id": "FR_004", "name": "under_trading", "condition": "total_trades < 50 AND profit_abs < 0", "action": "relax_entry", "params": ["entry_timeout", 0], "severity": 0.6},
        {"id": "FR_005", "name": "whipsaw_sensitivity", "condition": "total_trades > 100 AND win_rate < 0.45", "action": "add_confirmation", "params": ["confirm_timeout", 2], "severity": 0.7},
        {"id": "FR_006", "name": "signal_clustering", "condition": "trades_per_day > 5", "action": "add_cooldown", "params": ["cooldown_time", 1], "severity": 0.7},
        {"id": "FR_007", "name": "time_between_trades_low", "condition": "avg_trades_per_day > 3", "action": "add_cooldown", "params": ["cooldown_time", 1], "severity": 0.6},
        {"id": "FR_008", "name": "time_between_trades_high", "condition": "avg_trades_per_day < 0.5", "action": "relax_entry", "params": ["entry_timeout", 0], "severity": 0.5},
        {"id": "FR_009", "name": "entry_frequency_volatile", "condition": "trades_per_day_std > trades_per_day_mean", "action": "stabilize_entry", "params": ["entry_timeout", 3], "severity": 0.6},
        {"id": "FR_010", "name": "exit_frequency_volatile", "condition": "exits_per_day_std > exits_per_day_mean", "action": "stabilize_exit", "params": ["exit_timeout", 3], "severity": 0.6},
        {"id": "FR_011", "name": "cycle_time_too_short", "condition": "avg_trade_duration < 1", "action": "extend_cycle", "params": ["min_trade_duration", 1], "severity": 0.7},
        {"id": "FR_012", "name": "cycle_time_too_long", "condition": "avg_trade_duration > 20", "action": "shorten_cycle", "params": ["max_trade_duration", 10], "severity": 0.5},
        {"id": "FR_013", "name": "burst_trading", "condition": "trades_per_day > 5", "action": "add_cooldown", "params": ["cooldown_time", 2], "severity": 0.8},
        {"id": "FR_014", "name": "dead_time_excessive", "condition": "avg_trades_per_day < 0.3", "action": "relax_entry", "params": ["entry_timeout", 0], "severity": 0.6},
        {"id": "FR_015", "name": "inconsistent_frequency", "condition": "trades_per_day_cv > 0.5", "action": "stabilize_frequency", "params": ["entry_timeout", 2], "severity": 0.5}
      ]
    },
    {
      "name": "Entries",
