        {"id": "EN_001", "name": "entry_too_aggressive", "condition": "win_rate < 0.40", "action": "tighten_entry", "params": ["entry_timeout", 3], "severity": 0.8},
        {"id": "EN_002", "name": "entry_too_conservative", "condition": "total_trades < 30 AND profit_abs < 0", "action": "relax_entry", "params": ["entry_timeout", 0], "severity": 0.6},
        {"id": "EN_003", "name": "early_entry", "condition": "avg_trade_balance < 0 AND win_rate < 0.45", "action": "delay_entry", "params": ["entry_timeout", 2], "severity": 0.7},
        {"id": "EN_004", "name": "late_entry", "condition": "profit_factor < 1.2", "action": "earlier_entry", "params": ["entry_timeout", -1], "severity": 0.6},
        {"id": "EN_005", "name": "entry_timing_mismatch", "condition": "profit_factor < 1.0", "action": "fix_entry_timing", "params": ["entry_timeout", 1], "severity": 0.7},
