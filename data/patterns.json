        {"id": "PA_003", "name": "pair_correlation_high", "condition": "pair_correlation > 0.7", "action": "reduce_correlation", "params": ["max_correlation", 0.5], "severity": 0.7},
        {"id": "PA_004", "name": "pair_performance_variance", "condition": "pair_profit_std > pair_profit_mean", "action": "balance_pairs", "params": ["min_pairs", 4], "severity": 0.6},
