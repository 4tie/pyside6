        {"id": "EX_007", "name": "partial_exit_too_early", "condition": "profit_factor < 1.2", "action": "delay_partial_exit", "params": ["partial_exit_threshold", 0.02], "severity": 0.6},
        {"id": "EX_008", "name": "partial_exit_too_late", "condition": "max_drawdown > 15", "action": "earlier_partial_exit", "params": ["partial_exit_threshold", 0.01], "severity": 0.6},
        {"id": "EX_009", "name": "break_even_too_early", "condition": "win_rate < 0.45", "action": "delay_break_even", "params": ["break_even_delay", 2], "severity": 0.6},
        {"id": "EX_010", "name": "break_even_too_late", "condition": "max_drawdown > 10", "action": "earlier_break_even", "params": ["break_even_delay", 0], "severity": 0.6},
        {"id": "EX_011", "name": "time_based_exit_early", "condition": "avg_trade_balance < 0", "action": "disable_time_exit", "params": ["max_trade_duration", 0], "severity": 0.6},
        {"id": "EX_012", "name": "time_based_exit_late", "condition": "max_drawdown > 15", "action": "enable_time_exit", "params": ["max_trade_duration", 10], "severity": 0.6},
        {"id": "EX_013", "name": "exit_signal_conflict", "condition": "total_trades > 100", "action": "prioritize_exits", "params": ["max_exit_signals", 1], "severity": 0.6},
