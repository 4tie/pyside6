        {"id": "EN_007", "name": "missed_entry", "condition": "profit_factor > 1.3 AND total_trades < 50", "action": "relax_entry", "params": ["entry_timeout", 0], "severity": 0.6},
        {"id": "EN_008", "name": "entry_threshold_too_high", "condition": "total_trades < 40", "action": "lower_entry_threshold", "params": ["entry_timeout", 0], "severity": 0.6},
        {"id": "EN_009", "name": "entry_threshold_too_low", "condition": "total_trades > 150", "action": "raise_entry_threshold", "params": ["entry_timeout", 2], "severity": 0.7},
        {"id": "EN_010", "name": "signal_confirmation_weak", "condition": "win_rate < 0.45", "action": "add_confirmation", "params": ["confirm_timeout", 3], "severity": 0.7},
        {"id": "EN_011", "name": "multiple_signal_conflict", "condition": "total_trades > 100 AND win_rate < 0.45", "action": "prioritize_signals", "params": ["max_signals", 1], "severity": 0.7},
        {"id": "EN_012", "name": "entry_lag_high", "condition": "profit_factor < 1.2", "action": "reduce_entry_lag", "params": ["entry_timeout", -1], "severity": 0.6},
        {"id": "EN_013", "name": "volume_spike_entry", "condition": "total_trades > 100", "action": "filter_volume", "params": ["min_volume_ratio", 1.2], "severity": 0.6},
