        {"id": "PA_006", "name": "overconcentration", "condition": "top_3_pairs > total_profit * 0.7", "action": "reduce_concentration", "params": ["max_pair_weight", 0.25], "severity": 0.8},
        {"id": "PA_007", "name": "pair_instability", "condition": "pair_profit_cv > 1.0", "action": "stabilize_pairs", "params": ["min_pair_trades", 10], "severity": 0.6},
        {"id": "PA_008", "name": "pair_time_mismatch", "condition": "profit_factor < 1.2", "action": "align_pair_times", "params": ["entry_timeout", 1], "severity": 0.6},
        {"id": "PA_009", "name": "pair_volatility_mismatch", "condition": "pair_volatility_cv > 0.5", "action": "normalize_volatility", "params": ["volatility_adjust", true], "severity": 0.6},
        {"id": "PA_010", "name": "pair_regime_mismatch", "condition": "profit_factor < 1.0", "action": "diversify_regimes", "params": ["min_regimes", 2], "severity": 0.7},
        {"id": "PA_011", "name": "unused_pairs", "condition": "unused_pairs > 5", "action": "enable_pairs", "params": ["min_pairs", 3], "severity": 0.5},
        {"id": "PA_012", "name": "pair_overlap", "condition": "pair_signal_overlap > 0.5", "action": "reduce_overlap", "params": ["entry_timeout", 2], "severity": 0.6},
