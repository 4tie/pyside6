{
  "name": "q_ide_default",
  "description": "Default agent configuration",
  "prompt": "",
  "mcpServers": {
    "memory": {
      "command": "npx",
      "disabled": false,
      "timeout": 60000,
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "filesystem": {
      "command": "npx",
      "disabled": false,
      "timeout": 60000,
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "T:\\ae\\pyside6"
      ]
    },
    "Git": {
      "command": "uvx",
      "disabled": false,
      "timeout": 60000,
      "args": [
        "mcp-server-git"
      ]
    },
    "py git ": {
      "command": "T:\\ae\\pyside6\\.venv\\Scripts\\python.exe",
      "disabled": false,
      "timeout": 120000,
      "args": [
        "-m",
        "mcp_server_git"
      ]
    },
    "pyside6": {
      "command": "T:\\ae\\pyside6\\.venv\\Scripts\\python.exe",
      "disabled": false,
      "timeout": 120000,
      "args": [
        "T:\\ae\\pyside6\\mcp_pyside6.py"
      ]
    },
    "sequential-thinking": {
      "command": "npx",
      "disabled": false,
      "timeout": 60000,
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "taskflow": {
      "command": "npx",
      "disabled": false,
      "timeout": 60000,
      "args": [
        "-y",
        "@pinkpixel/taskflow-mcp"
      ],
      "env": {
        "TASK_MANAGER_FILE_PATH": "T:\\ae\\pyside6\\.ai\\tasks.yaml",
        "TASK_MANAGER_BASE_DIR": "T:\\ae\\pyside6",
        "ARCHIVE_FILE_PATH": "T:\\ae\\pyside6\\.ai\\tasks-archive.yaml",
        "ARCHIVE_MODE": "manual"
      }
    }
  },
  "tools": [
    "fs_read",
    "execute_bash",
    "fs_write",
    "report_issue",
    "use_aws",
    "@memory",
    "@filesystem",
    "@Git",
    "@py git ",
    "@pyside6",
    "@sequential-thinking",
    "@taskflow"
  ],
  "toolAliases": {},
  "allowedTools": [
    "fs_read",
    "report_issue",
    "use_aws",
    "execute_bash",
    "fs_write",
    "@memory/create_entities",
