# OpenRouter API Keys
# Add your OpenRouter API keys here (comma-separated for multiple keys)
OPENROUTER_API_KEY=your_openrouter_api_key_here
OPENROUTER_API_KEYS=key1,key2,key3

# Ollama Configuration (optional)
OLLAMA_BASE_URL=http://localhost:11434

# AI Provider Settings (optional)
# AI_PROVIDER=openrouter
# AI_CHAT_MODEL=openai/gpt-4o-mini
# AI_TASK_MODEL=openai/gpt-4o-mini
# AI_STREAM_ENABLED=true
# AI_TOOLS_ENABLED=false

# Web Server Settings (optional)
WEB_HOST=0.0.0.0   # Bind address for run_web.py (default: 0.0.0.0)
WEB_PORT=8000      # TCP port for run_web.py (default: 8000)
