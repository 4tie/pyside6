{
  "mcpServers": {
    "memory": {
      "command": "npx",
      "disabled": false,
      "timeout": 60000,
      "args": [
        "-y",
        "@modelcontextprotocol/server-memory"
      ]
    },
    "filesystem": {
      "command": "npx",
      "disabled": false,
      "timeout": 60000,
      "args": [
        "-y",
        "@modelcontextprotocol/server-filesystem",
        "T:\\ae\\pyside6"
      ]
    },
    "git": {
      "command": "uvx",
      "disabled": false,
      "timeout": 60000,
      "args": [
        "mcp-server-git"
      ]
    },
    "sequential-thinking": {
      "command": "npx",
      "disabled": false,
      "timeout": 60000,
      "args": [
        "-y",
        "@modelcontextprotocol/server-sequential-thinking"
      ]
    },
    "taskflow": {
      "command": "npx",
      "disabled": false,
      "timeout": 60000,
      "args": [
        "-y",
        "@pinkpixel/taskflow-mcp"
      ],
      "env": {
        "TASK_MANAGER_FILE_PATH": "T:\\ae\\pyside6\\.ai\\tasks.yaml",
        "TASK_MANAGER_BASE_DIR": "T:\\ae\\pyside6",
        "ARCHIVE_FILE_PATH": "T:\\ae\\pyside6\\.ai\\tasks-archive.yaml",
        "ARCHIVE_MODE": "manual"
      }
    }
  }
}
